{
  "name": "telegram-pi-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/index.mjs",
    "check": "node --check src/index.mjs && node --check src/manage.mjs && node --check src/tui.mjs && node --check src/manager-lib.mjs",
    "bridge:start": "node src/manage.mjs start",
    "bridge:stop": "node src/manage.mjs stop",
    "bridge:restart": "node src/manage.mjs restart",
